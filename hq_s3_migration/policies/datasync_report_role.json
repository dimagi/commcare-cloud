{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Action": [
        "s3:PutObject"
      ],
      "Effect": "Allow",
      "Resource": "arn:aws:s3:::{report_bucket}/*",
      "Condition": {
        "StringEquals": {
          "s3:ResourceAccount": "{source_account_id}"
        }
      }
    }
  ]
}
