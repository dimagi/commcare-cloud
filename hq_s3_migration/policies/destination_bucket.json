{
  "Version": "2012-10-17",
  "Id": "PolicyForCrossAccountReplication",
  "Statement": [
    {
      "Sid": "AllowReplicationFromSource",
      "Effect": "Allow",
      "Principal": {
        "AWS": "{role_arn}"
      },
      "Action": [
        "s3:List*",
        "s3:GetBucketVersioning",
        "s3:PutBucketVersioning",
        "s3:ReplicateDelete",
        "s3:ReplicateObject"
      ],
      "Resource": [
        "arn:aws:s3:::{dest_bucket}",
        "arn:aws:s3:::{dest_bucket}/*"
      ]
    },
    {
      "Sid": "AllowBucketOwnerOverride",
      "Effect": "Allow",
      "Principal": {
        "AWS": "{role_arn}"
      },
      "Action": "s3:ObjectOwnerOverrideToBucketOwner",
      "Resource": "arn:aws:s3:::{dest_bucket}/*"
    }
  ]
}
